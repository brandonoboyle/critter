{
  "name": "critter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run dev",
    "build": "npm run build:wasm:release && npm run lint && tsc && vite build",
    "build:wasm": "wasm-pack build core --dev --target web --out-dir ../src/wasm",
    "build:wasm:release": "wasm-pack build core --target web --out-dir ../src/wasm",
    "lint": "eslint .",
    "dev": "npm run build:wasm && vite"
  },
  "dependencies": {
    "pixi.js": "^8.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "prettier": "^3.5.3",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.25.0",
    "vite": "^6.2.0"
  }
}
